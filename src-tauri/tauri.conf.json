{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Datlino",
  "version": "0.1.0",
  "identifier": "org.datlino.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Datlino",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "shortDescription": "Touch-typing trainer for Czech and Slovak high school students.",
    "longDescription": "Datlino drills students on the actual content they are studying — type the phrases from your own textbooks, notes, and GoodNotes exports while building real WPM and accuracy.",
    "category": "Education",
    "copyright": "© 2026 Paja Dravec",
    "publisher": "Paja Dravec",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": null
    },
    "windows": {
      "wix": {
        "language": ["en-US", "cs-CZ"]
      }
    }
  }
}
